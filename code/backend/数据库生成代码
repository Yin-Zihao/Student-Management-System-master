-- 竞赛获奖表
CREATE TABLE competition_award (
    id INT IDENTITY(1,1) PRIMARY KEY,          -- 主键ID
    college VARCHAR(100),                       -- 学院
    certificate_no VARCHAR(50),                 -- 证书编号
    student_id VARCHAR(20),                     -- 学号
    name VARCHAR(50),                           -- 学生姓名
    major VARCHAR(100),                         -- 专业
    grade INT,                                  -- 年级
    competition_name VARCHAR(200),              -- 竞赛名称
    organizer VARCHAR(200),                     -- 主办单位
    award_level VARCHAR(50),                    -- 获奖级别（国家级/省级等）
    award_rank VARCHAR(50),                     -- 获奖等次（一等奖/二等奖等）
    remark1 VARCHAR(200),                       -- 备注1
    track VARCHAR(100),                         -- 赛道
    project_name VARCHAR(200),                  -- 项目名称
    award_type VARCHAR(20)                      -- 获奖类型（团队/个人）
);

-- 团队获奖详情表
CREATE TABLE team_award (
    id INT IDENTITY(1,1) PRIMARY KEY,          -- 主键ID
    competition_award_id INT,                   -- 关联竞赛获奖表ID
    team_size INT,                              -- 团队人数
    personal_rank VARCHAR(50),                  -- 个人排名
    team_members TEXT,                          -- 团队成员名单
    award_date DATE,                            -- 获奖日期
    approval_url VARCHAR(300),                  -- 审批链接
    advisor1_name VARCHAR(50),                  -- 第一指导教师姓名
    advisor1_college VARCHAR(100),              -- 第一指导教师所在学院
    advisor2_name VARCHAR(50),                  -- 第二指导教师姓名
    advisor2_college VARCHAR(100),              -- 第二指导教师所在学院
    remark2 VARCHAR(200),                       -- 备注2
    FOREIGN KEY (competition_award_id) REFERENCES competition_award(id)
);

